# AXYX — research project ignore rules
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.ipynb_checkpoints/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Environments
venv/
venv311/
.env
.venv/

# Avatar / environment source assets stay local (FBX/TGA/NPZ too large for GitHub)
assets/

# KILI raw Unreal exports (large); runtime cache may be committed for clone-without-FBX
KILI/*.FBX
KILI/*.fbx
KILI/*.TGA
KILI/*.tga
KILI/cache/*.npz
!KILI/cache/body_lod1.npz
!KILI/cache/body_lod2.npz
!KILI/cache/body_lod3.npz
!KILI/cache/outfit_lod0.npz
KILI/cache/textures/*
!KILI/cache/textures/body_bc.png
!KILI/cache/textures/body_n.png
!KILI/cache/textures/body_srmf.png
!KILI/cache/textures/body_scatter.png
KILI/cache/_*.json

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Local runtime / captures
logs/
out/
output/
*.log
DepthCapture_*.png
DepthCamera_*.json
ScreenCapture_*.png
ScreenCamera_*.json

# Large / local data (keep structure; ignore bulky binaries)
data/raw/**
!data/raw/.gitkeep
data/processed/**
!data/processed/.gitkeep
*.mat
Victimization surveys.xlsx
anaconda_projects/

# Results may be regenerated
results/exports/*
!results/exports/.gitkeep
results/figures/*
!results/figures/.gitkeep
